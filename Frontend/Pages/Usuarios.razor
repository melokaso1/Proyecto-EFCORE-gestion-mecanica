@page "/usuarios"
@layout MainLayout
@attribute [Authorize(Roles = "Admin,Recepcionista")]
@inject IUsuariosService UsuariosService
@inject AuthService Auth
@using System.Globalization

<PageTitle>Usuarios — Mecánicas Jholversito</PageTitle>

<div class="max-w-6xl mx-auto space-y-8 pb-8">
    <header class="flex flex-col gap-4 border-b border-slate-200 pb-8 lg:flex-row lg:items-end lg:justify-between">
        <div class="space-y-2">
            <p class="text-xs font-semibold uppercase tracking-widest text-red-600">Administración</p>
            <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Usuarios y roles</h1>
            <p class="max-w-2xl text-sm leading-relaxed text-slate-600">
                Asigna o cambia el rol del personal. Los usuarios sin rol no pueden acceder al sistema hasta que completes la asignación.
            </p>
        </div>
        <div class="flex flex-wrap items-center gap-2">
            <button type="button"
                    class="inline-flex items-center justify-center rounded-xl border border-red-200 bg-red-50 px-4 py-2.5 text-sm font-semibold text-red-800 shadow-sm transition hover:bg-red-100"
                    @onclick="() => mostrarFormularioRegistro = !mostrarFormularioRegistro">
                @(mostrarFormularioRegistro ? "Ocultar formulario" : "Registrar usuario")
            </button>
            <a href="/admin"
               class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 shadow-sm transition hover:border-slate-300 hover:bg-slate-50">
                Volver al panel
            </a>
            <button type="button"
                    disabled="@cargando"
                    class="inline-flex items-center justify-center gap-2 rounded-xl bg-red-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-red-700 disabled:cursor-not-allowed disabled:opacity-50"
                    @onclick="CargarUsuariosAsync">
                @if (cargando)
                {
                    <span class="h-4 w-4 animate-spin rounded-full border-2 border-white/40 border-t-white"></span>
                    <span>Actualizando</span>
                }
                else
                {
                    <span>Refrescar lista</span>
                }
            </button>
        </div>
    </header>

    @if (mostrarFormularioRegistro)
    {
        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-slate-900/5 space-y-4">
            <div>
                <h2 class="text-lg font-semibold text-slate-900">Nuevo usuario</h2>
                <p class="text-sm text-slate-600 mt-1">Solo admin y recepción pueden registrar cuentas. Asigna el rol después si lo dejas pendiente.</p>
            </div>
            @if (!string.IsNullOrWhiteSpace(mensajeRegistroError))
            {
                <p class="text-sm text-red-700 rounded-xl bg-red-50 border border-red-100 px-4 py-3">@mensajeRegistroError</p>
            }
            @if (!string.IsNullOrWhiteSpace(mensajeRegistroExito))
            {
                <p class="text-sm text-emerald-800 rounded-xl bg-emerald-50 border border-emerald-100 px-4 py-3">@mensajeRegistroExito</p>
            }
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div>
                    <label class="block text-xs font-semibold uppercase tracking-wide text-slate-500 mb-1">Nombres</label>
                    <input type="text" @bind="nuevoUsuario.Nombres"
                           class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm focus:border-red-400 focus:outline-none focus:ring-2 focus:ring-red-500/20" />
                </div>
                <div>
                    <label class="block text-xs font-semibold uppercase tracking-wide text-slate-500 mb-1">Apellidos</label>
                    <input type="text" @bind="nuevoUsuario.Apellidos"
                           class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm focus:border-red-400 focus:outline-none focus:ring-2 focus:ring-red-500/20" />
                </div>
                <div>
                    <label class="block text-xs font-semibold uppercase tracking-wide text-slate-500 mb-1">Correo</label>
                    <input type="email" @bind="nuevoUsuario.Correo" placeholder="usuario@dominio.com"
                           class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm focus:border-red-400 focus:outline-none focus:ring-2 focus:ring-red-500/20" />
                </div>
                <div>
                    <label class="block text-xs font-semibold uppercase tracking-wide text-slate-500 mb-1">Contraseña</label>
                    <input type="password" @bind="nuevoUsuario.Password"
                           class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm focus:border-red-400 focus:outline-none focus:ring-2 focus:ring-red-500/20" />
                </div>
            </div>
            <button type="button"
                    disabled="@registrandoUsuario"
                    class="inline-flex items-center justify-center gap-2 rounded-xl bg-red-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-red-700 disabled:opacity-50"
                    @onclick="RegistrarUsuarioAsync">
                @if (registrandoUsuario)
                {
                    <span class="h-4 w-4 animate-spin rounded-full border-2 border-white/40 border-t-white"></span>
                    <span>Registrando...</span>
                }
                else
                {
                    <span>Crear cuenta</span>
                }
            </button>
        </section>
    }

    @if (!cargando && string.IsNullOrWhiteSpace(mensajeError))
    {
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
            <div class="rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm ring-1 ring-slate-900/5">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Total en sistema</p>
                <p class="mt-2 text-3xl font-bold tabular-nums text-slate-900">@totalUsuarios</p>
            </div>
            <div class="rounded-2xl border border-red-200 bg-red-50/80 p-5 shadow-sm ring-1 ring-red-900/5">
                <p class="text-xs font-semibold uppercase tracking-wide text-red-800">Sin rol asignado</p>
                <p class="mt-2 text-3xl font-bold tabular-nums text-red-900">@pendientesSinRol</p>
                <p class="mt-1 text-xs text-red-700">Requieren acción</p>
            </div>
            <div class="rounded-2xl border border-slate-200/80 bg-slate-50 p-5 shadow-sm ring-1 ring-slate-900/5">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Coinciden filtro</p>
                <p class="mt-2 text-3xl font-bold tabular-nums text-slate-900">@UsuariosVisibles.Count()</p>
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(mensajeExito))
    {
        <div class="flex items-start justify-between gap-4 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 shadow-sm" role="status">
            <p class="text-sm font-medium text-emerald-900">@mensajeExito</p>
            <button type="button"
                    class="shrink-0 rounded-lg px-2 py-1 text-xs font-semibold text-emerald-800 hover:bg-emerald-100"
                    @onclick="() => mensajeExito = null">
                Cerrar
            </button>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(mensajeError))
    {
        <div class="flex items-start justify-between gap-4 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 shadow-sm" role="alert">
            <p class="text-sm font-medium text-red-900">@mensajeError</p>
            <button type="button"
                    class="shrink-0 rounded-lg px-2 py-1 text-xs font-semibold text-red-800 hover:bg-red-100"
                    @onclick="() => mensajeError = null">
                Cerrar
            </button>
        </div>
    }

    @if (!cargando && string.IsNullOrWhiteSpace(mensajeError))
    {
        <div class="flex flex-col gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm ring-1 ring-slate-900/5 sm:flex-row sm:flex-wrap sm:items-end sm:justify-between">
            <div class="min-w-0 flex-1 sm:max-w-md">
                <label for="filtro-usuarios" class="block text-xs font-semibold uppercase tracking-wide text-slate-500">Buscar</label>
                <input id="filtro-usuarios"
                       type="search"
                       @bind="filtroTexto"
                       @bind:event="oninput"
                       placeholder="Nombre o correo"
                       class="mt-1.5 w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm text-slate-900 placeholder-slate-400 shadow-inner focus:border-red-400 focus:outline-none focus:ring-2 focus:ring-red-500/20" />
            </div>
            <label class="inline-flex cursor-pointer select-none items-center gap-2 rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-red-200 hover:bg-red-50/50">
                <input type="checkbox"
                       class="h-4 w-4 rounded border-slate-300 text-red-600 focus:ring-red-500"
                       @bind="soloPendientes" />
                Solo pendientes de rol
            </label>
        </div>
    }

    @if (cargando)
    {
        <div class="space-y-3 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="h-4 w-1/3 animate-pulse rounded bg-slate-200"></div>
            @for (var i = 0; i < 6; i++)
            {
                <div class="h-12 animate-pulse rounded-lg bg-slate-100"></div>
            }
        </div>
    }
    else if (string.IsNullOrWhiteSpace(mensajeError))
    {
        <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm ring-1 ring-slate-900/5">
            <div class="overflow-x-auto">
                <table class="min-w-full border-collapse text-left text-sm">
                    <thead class="sticky top-0 z-10 border-b border-slate-200 bg-slate-100/95 backdrop-blur-sm">
                        <tr>
                            <th scope="col" class="whitespace-nowrap px-4 py-3.5 text-xs font-semibold uppercase tracking-wide text-slate-600">Usuario</th>
                            <th scope="col" class="whitespace-nowrap px-4 py-3.5 text-xs font-semibold uppercase tracking-wide text-slate-600">Correo</th>
                            <th scope="col" class="whitespace-nowrap px-4 py-3.5 text-xs font-semibold uppercase tracking-wide text-slate-600">Rol actual</th>
                            <th scope="col" class="min-w-[18rem] whitespace-nowrap px-4 py-3.5 text-xs font-semibold uppercase tracking-wide text-slate-600">Configuración</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @if (!UsuariosVisibles.Any())
                        {
                            <tr>
                                <td colspan="4" class="px-4 py-16 text-center">
                                    <p class="text-sm font-medium text-slate-700">No hay resultados</p>
                                    <p class="mt-1 text-xs text-slate-500">Prueba otro criterio de búsqueda o desactiva el filtro de pendientes.</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var usuario in UsuariosVisibles)
                            {
                                var roles = usuario.Roles ?? [];
                                var esAdmin = roles.Contains("Admin");
                                var esMecanico = roles.Contains("Mecánico");
                                var mostrarEsp = EsMecanicoParaEspecializaciones(usuario.IdUsuario, esMecanico);
                                var sinRol = roles.Count == 0;
                                var puedeEliminar = PuedeEliminarUsuario(usuario, esAdmin);
                                <tr @key="usuario.IdUsuario" class="@(sinRol ? "bg-red-50/40" : "hover:bg-slate-50/80") transition-colors">
                                    <td class="px-4 py-3.5 align-middle">
                                        <div class="flex flex-wrap items-center gap-2">
                                            <span class="font-medium text-slate-900">@usuario.NombreCompleto</span>
                                            @if (sinRol)
                                            {
                                                <span class="inline-flex rounded-full bg-red-100 px-2 py-0.5 text-xs font-semibold text-red-800 ring-1 ring-inset ring-red-200">Pendiente</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="px-4 py-3.5 align-middle">
                                        <span class="font-mono text-xs text-slate-600 sm:text-sm">@usuario.Correo</span>
                                    </td>
                                    <td class="px-4 py-3.5 align-middle">
                                        @if (esAdmin)
                                        {
                                            <span class="inline-flex rounded-full bg-slate-800 px-2.5 py-1 text-xs font-semibold text-white">Admin</span>
                                        }
                                        else if (sinRol)
                                        {
                                            <span class="text-xs font-medium italic text-red-600">Sin rol</span>
                                        }
                                        else
                                        {
                                            <div class="flex flex-wrap gap-1">
                                                @foreach (var r in roles)
                                                {
                                                    <span class="@RolBadgeClass(r) inline-flex rounded-full px-2.5 py-1 text-xs font-semibold">@r</span>
                                                }
                                            </div>
                                            @if (mostrarEsp && (usuario.Especializaciones ?? []).Count > 0)
                                            {
                                                <div class="mt-2 flex flex-wrap gap-1">
                                                    @foreach (var esp in usuario.Especializaciones!)
                                                    {
                                                        <span class="inline-flex rounded-full bg-slate-100 px-2 py-0.5 text-[11px] font-medium text-slate-600 ring-1 ring-inset ring-slate-200">@esp.Nombre</span>
                                                    }
                                                </div>
                                            }
                                        }
                                    </td>
                                    <td class="overflow-visible px-4 py-3.5 align-middle">
                                        @if (esAdmin)
                                        {
                                            <span class="text-xs text-slate-400">Cuenta protegida</span>
                                        }
                                        else
                                        {
                                            var seleccionadas = ContarEspecializaciones(usuario.IdUsuario);
                                            var espDropdownAbierto = dropdownEspAbiertoId == usuario.IdUsuario;
                                            var idRolSel = rolesSeleccionados.GetValueOrDefault(usuario.IdUsuario);
                                            var espSel = especializacionesSeleccionadas.GetValueOrDefault(usuario.IdUsuario) ?? [];
                                            var puedeGuardar = PuedeGuardarConfiguracion(idRolSel, seleccionadas)
                                                && (sinRol || HayCambiosPendientes(usuario, idRolSel, espSel));

                                            <div class="@(mostrarEsp ? EditorPanelClass : EditorPanelClassSoloRol)">
                                                <span class="@($"{EditorLabelClass} col-start-1 row-start-1")">Rol</span>
                                                <select class="@($"{SelectFieldClass} col-start-2 row-start-1")"
                                                        value="@idRolSel"
                                                        @onchange="(e) => OnRolSeleccionadoChanged(usuario.IdUsuario, e)">
                                                    <option value="0">Seleccionar…</option>
                                                    <option value="2">Mecánico</option>
                                                    <option value="3">Recepcionista</option>
                                                    <option value="4">Cliente</option>
                                                    <option value="5">Jefe de mecánicos</option>
                                                    <option value="6">Jefe de bodega</option>
                                                </select>

                                                @if (mostrarEsp)
                                                {
                                                    <span class="@($"{EditorLabelClass} col-start-1 row-start-2")">Áreas</span>
                                                    <div class="relative col-start-2 row-start-2 min-w-0 space-y-1">
                                                        <p class="text-[11px] text-slate-500">Obligatorio para Mecánico</p>
                                                        <div class="relative h-10 min-h-10">
                                                        <button type="button"
                                                                class="@($"{SelectFieldClass} block w-full cursor-pointer truncate text-left")"
                                                                aria-expanded="@espDropdownAbierto"
                                                                @onclick="() => ToggleEspDropdown(usuario.IdUsuario)">
                                                            @ResumenEspecializaciones(usuario.IdUsuario, especializacionesSeleccionadas)
                                                        </button>
                                                        @if (espDropdownAbierto)
                                                        {
                                                            <div class="absolute bottom-full left-0 right-0 z-30 mb-1 max-h-52 overflow-y-auto rounded-xl border border-slate-200 bg-white py-1 shadow-lg ring-1 ring-slate-900/5"
                                                                 @onclick:stopPropagation="true">
                                                                @foreach (var esp in catalogoEspecializaciones)
                                                                {
                                                                    var idEsp = esp.IdEspecializacionMecanico;
                                                                    var marcada = EspecializacionSeleccionada(usuario.IdUsuario, idEsp);
                                                                    <label class="flex cursor-pointer items-center gap-2.5 px-3 py-2 text-sm text-slate-800 hover:bg-slate-50">
                                                                        <input type="checkbox"
                                                                               class="h-4 w-4 rounded border-slate-300 text-red-600 focus:ring-red-500"
                                                                               checked="@marcada"
                                                                               @onchange="(e) => OnEspecializacionCheckboxChanged(usuario.IdUsuario, idEsp, e)" />
                                                                        <span class="truncate" title="@ObtenerTituloEspecializacion(esp)">@esp.Nombre</span>
                                                                    </label>
                                                                }
                                                            </div>
                                                        }
                                                        </div>
                                                        @if (idRolSel == 2 && seleccionadas == 0)
                                                        {
                                                            <p class="text-[11px] font-medium text-amber-700">Selecciona al menos un área para guardar como Mecánico.</p>
                                                        }
                                                    </div>
                                                }

                                                <button type="button"
                                                        disabled="@(guardandoId == usuario.IdUsuario || !puedeGuardar)"
                                                        class="@($"{SaveButtonClass} col-start-3 row-start-1 self-center {(mostrarEsp ? "row-span-2" : "")}")"
                                                        @onclick="() => GuardarConfiguracionAsync(usuario)">
                                                    @if (guardandoId == usuario.IdUsuario)
                                                    {
                                                        <span class="h-3.5 w-3.5 animate-spin rounded-full border-2 border-white/30 border-t-white"></span>
                                                    }
                                                    <span>@(sinRol ? "Asignar" : "Guardar")</span>
                                                </button>

                                                @if (puedeEliminar)
                                                {
                                                    <div class="@(mostrarEsp ? "col-span-3 row-start-3 border-t border-slate-100 pt-2" : "col-span-3 row-start-2 border-t border-slate-100 pt-2")">
                                                        <button type="button"
                                                                class="text-xs font-medium text-red-600 hover:text-red-800 hover:underline"
                                                                @onclick="() => AbrirModalEliminar(usuario)">
                                                            Eliminar usuario
                                                        </button>
                                                    </div>
                                                }
                                                else if (EsUsuarioActual(usuario.IdUsuario))
                                                {
                                                    <p class="@(mostrarEsp ? "col-span-3 row-start-3 border-t border-slate-100 pt-2 text-xs text-slate-400" : "col-span-3 row-start-2 border-t border-slate-100 pt-2 text-xs text-slate-400")">Tu cuenta</p>
                                                }
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (dropdownEspAbiertoId is not null)
{
    <button type="button"
            class="fixed inset-0 z-20 cursor-default bg-transparent"
            aria-label="Cerrar menú"
            @onclick="CerrarEspDropdown"></button>
}

@if (usuarioAEliminar is not null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4" role="dialog" aria-modal="true" aria-labelledby="eliminar-usuario-titulo">
        <div class="w-full max-w-md rounded-2xl bg-white shadow-xl ring-1 ring-slate-900/10">
            <div class="border-b border-slate-200 px-6 py-4">
                <h2 id="eliminar-usuario-titulo" class="text-lg font-semibold text-slate-900">Eliminar usuario</h2>
                <p class="mt-1 text-sm text-slate-600">
                    Se eliminará la cuenta de <span class="font-medium text-slate-900">@usuarioAEliminar.NombreCompleto</span>
                    (<span class="font-mono text-xs">@usuarioAEliminar.Correo</span>). No podrá iniciar sesión y dejará de aparecer en la lista.
                </p>
                <p class="mt-2 text-sm text-slate-500">
                    El registro se conserva en la base de datos para mantener la trazabilidad del historial.
                </p>
            </div>
            <div class="flex flex-col-reverse gap-2 px-6 py-4 sm:flex-row sm:justify-end">
                <button type="button"
                        disabled="@eliminandoUsuario"
                        class="inline-flex justify-center rounded-xl border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 disabled:opacity-50"
                        @onclick="CerrarModalEliminar">
                    Cancelar
                </button>
                <button type="button"
                        disabled="@eliminandoUsuario"
                        class="inline-flex items-center justify-center gap-2 rounded-xl bg-red-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-red-700 disabled:opacity-50"
                        @onclick="ConfirmarEliminarAsync">
                    @if (eliminandoUsuario)
                    {
                        <span class="h-4 w-4 animate-spin rounded-full border-2 border-white/40 border-t-white"></span>
                        <span>Eliminando…</span>
                    }
                    else
                    {
                        <span>Sí, eliminar</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private const string EditorPanelClass =
        "grid min-h-[5.75rem] min-w-[17rem] max-w-md grid-cols-[3.25rem_minmax(0,1fr)_5.5rem] grid-rows-[2.5rem_2.5rem_auto] items-center gap-x-2 gap-y-2.5";

    private const string EditorPanelClassSoloRol =
        "grid min-w-[17rem] max-w-md grid-cols-[3.25rem_minmax(0,1fr)_5.5rem] grid-rows-[2.5rem_auto] items-center gap-x-2 gap-y-2.5";

    private const string EditorLabelClass =
        "text-xs font-medium text-slate-500";

    private const string SelectChevronBg =
        "appearance-none bg-[length:1.25rem_1.25rem] bg-[position:right_0.625rem_center] bg-no-repeat pr-9 bg-[image:url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2020%2020%22%20fill%3D%22%2364748b%22%3E%3Cpath%20fill-rule%3D%22evenodd%22%20d%3D%22M5.293%207.293a1%201%200%20011.414%200L10%2010.586l3.293-3.293a1%201%200%20111.414%201.414l-4%204a1%201%200%2001-1.414%200l-4-4a1%201%200%20010-1.414z%22%20clip-rule%3D%22evenodd%22%2F%3E%3C/svg%3E')]";

    private const string SelectFieldClass =
        $"h-10 w-full min-w-0 rounded-xl border border-slate-200 bg-white px-3 text-sm leading-10 text-slate-900 shadow-sm focus:border-red-400 focus:outline-none focus:ring-2 focus:ring-red-500/25 {SelectChevronBg}";

    private const string SaveButtonClass =
        "inline-flex h-10 shrink-0 items-center justify-center gap-1.5 rounded-xl bg-red-600 px-3 text-xs font-semibold text-white shadow-sm transition hover:bg-red-700 disabled:cursor-not-allowed disabled:opacity-45";

    private List<UsuarioDto> usuarios = [];
    private readonly Dictionary<int, int> rolesSeleccionados = [];
    private readonly Dictionary<int, HashSet<int>> especializacionesSeleccionadas = [];
    private List<EspecializacionMecanicoDto> catalogoEspecializaciones = [];
    private readonly RegisterUserDto nuevoUsuario = new();
    private bool cargando = true;
    private bool mostrarFormularioRegistro;
    private bool registrandoUsuario;
    private string? mensajeRegistroError;
    private string? mensajeRegistroExito;
    private int? guardandoId;
    private int? dropdownEspAbiertoId;
    private UsuarioDto? usuarioAEliminar;
    private bool eliminandoUsuario;
    private string? mensajeExito;
    private string? mensajeError;
    private int totalUsuarios;
    private int pendientesSinRol;
    private string filtroTexto = string.Empty;
    private bool soloPendientes;

    private IEnumerable<UsuarioDto> UsuariosVisibles =>
        usuarios.Where(u =>
        {
            var roles = u.Roles ?? [];
            if (soloPendientes && roles.Count > 0)
                return false;

            var q = filtroTexto.Trim();
            if (string.IsNullOrEmpty(q))
                return true;

            return (u.NombreCompleto?.Contains(q, StringComparison.OrdinalIgnoreCase) == true)
                   || (u.Correo?.Contains(q, StringComparison.OrdinalIgnoreCase) == true);
        });

    private static string RolBadgeClass(string rol) => rol switch
    {
        "Mecánico" => "bg-red-100 text-red-900 ring-1 ring-inset ring-red-200",
        "Recepcionista" => "bg-slate-100 text-slate-800 ring-1 ring-inset ring-slate-200",
        "Cliente" => "bg-blue-100 text-blue-900 ring-1 ring-inset ring-blue-200",
        "JefeMecanicos" => "bg-amber-100 text-amber-900 ring-1 ring-inset ring-amber-200",
        "JefeBodega" => "bg-violet-100 text-violet-900 ring-1 ring-inset ring-violet-200",
        _ => "bg-slate-100 text-slate-700 ring-1 ring-inset ring-slate-200"
    };

    private static bool EsRolAsignable(int idRol) => idRol is 2 or 3 or 4 or 5 or 6;

    private static bool PuedeGuardarConfiguracion(int idRol, int _) =>
        EsRolAsignable(idRol);

    private static bool HayCambiosPendientes(UsuarioDto usuario, int idRolSel, HashSet<int> espSel)
    {
        var rolActual = RolNombreToId((usuario.Roles ?? []).FirstOrDefault());
        if (rolActual != idRolSel)
            return true;

        if (idRolSel != 2)
            return false;

        var guardadas = (usuario.Especializaciones ?? [])
            .Select(e => e.IdEspecializacionMecanico)
            .OrderBy(x => x)
            .ToList();
        var seleccionadas = espSel.OrderBy(x => x).ToList();
        return !guardadas.SequenceEqual(seleccionadas);
    }

    private static int RolNombreToId(string? nombre) => nombre switch
    {
        "Mecánico" => 2,
        "Recepcionista" => 3,
        "Cliente" => 4,
        "JefeMecanicos" => 5,
        "JefeBodega" => 6,
        _ => 0
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            catalogoEspecializaciones = await UsuariosService.GetEspecializacionesAsync();
        }
        catch
        {
            catalogoEspecializaciones = [];
        }

        await CargarUsuariosAsync();
    }

    private bool EsUsuarioActual(int idUsuario) =>
        Auth.GetUserId() == idUsuario;

    private bool PuedeEliminarUsuario(UsuarioDto usuario, bool esAdmin) =>
        !esAdmin && !EsUsuarioActual(usuario.IdUsuario);

    private bool EsMecanicoParaEspecializaciones(int idUsuario, bool esMecanico) =>
        esMecanico || rolesSeleccionados.GetValueOrDefault(idUsuario) == 2;

    private bool EspecializacionSeleccionada(int idUsuario, int idEsp) =>
        especializacionesSeleccionadas.TryGetValue(idUsuario, out var set) && set.Contains(idEsp);

    private int ContarEspecializaciones(int idUsuario) =>
        especializacionesSeleccionadas.GetValueOrDefault(idUsuario)?.Count ?? 0;

    private static string ObtenerTituloEspecializacion(EspecializacionMecanicoDto esp) =>
        string.IsNullOrWhiteSpace(esp.Descripcion) ? esp.Nombre : $"{esp.Nombre}: {esp.Descripcion}";

    private static string ResumenEspecializaciones(int idUsuario, Dictionary<int, HashSet<int>> seleccionadas)
    {
        var count = seleccionadas.GetValueOrDefault(idUsuario)?.Count ?? 0;
        return count switch
        {
            0 => "Seleccionar…",
            1 => "1 área",
            _ => $"{count} áreas"
        };
    }

    private void ToggleEspDropdown(int idUsuario) =>
        dropdownEspAbiertoId = dropdownEspAbiertoId == idUsuario ? null : idUsuario;

    private void CerrarEspDropdown() => dropdownEspAbiertoId = null;

    private void OnEspecializacionCheckboxChanged(int idUsuario, int idEsp, ChangeEventArgs e)
    {
        if (!especializacionesSeleccionadas.TryGetValue(idUsuario, out var set))
        {
            set = [];
            especializacionesSeleccionadas[idUsuario] = set;
        }

        var marcada = e.Value is bool b && b;
        if (marcada)
            set.Add(idEsp);
        else
            set.Remove(idEsp);
    }

    private void AbrirModalEliminar(UsuarioDto usuario) => usuarioAEliminar = usuario;

    private void CerrarModalEliminar()
    {
        if (eliminandoUsuario)
            return;
        usuarioAEliminar = null;
    }

    private async Task ConfirmarEliminarAsync()
    {
        if (usuarioAEliminar is null)
            return;

        mensajeExito = null;
        mensajeError = null;
        eliminandoUsuario = true;
        try
        {
            var (success, error) = await UsuariosService.EliminarUsuarioAsync(usuarioAEliminar.IdUsuario);
            if (!success)
            {
                mensajeError = error;
                return;
            }

            mensajeExito = $"Usuario {usuarioAEliminar.NombreCompleto} eliminado correctamente.";
            usuarioAEliminar = null;
            await CargarUsuariosAsync();
        }
        finally
        {
            eliminandoUsuario = false;
        }
    }

    private async Task GuardarConfiguracionAsync(UsuarioDto usuario)
    {
        var idUsuario = usuario.IdUsuario;
        mensajeExito = null;
        mensajeError = null;

        if (!rolesSeleccionados.TryGetValue(idUsuario, out var idRol) || !EsRolAsignable(idRol))
        {
            mensajeError = "Selecciona un rol válido.";
            return;
        }

        var seleccionadas = ContarEspecializaciones(idUsuario);
        if (idRol == 2 && seleccionadas == 0)
        {
            mensajeError = "Un mecánico debe tener al menos un área de trabajo.";
            return;
        }

        guardandoId = idUsuario;
        try
        {
            var (rolOk, rolErr) = await UsuariosService.AsignarRolAsync(idUsuario, idRol);
            if (!rolOk)
            {
                mensajeError = rolErr;
                return;
            }

            if (idRol == 2)
            {
                var ids = especializacionesSeleccionadas.GetValueOrDefault(idUsuario)?.ToList() ?? [];
                var (espOk, espErr) = await UsuariosService.AsignarEspecializacionesAsync(idUsuario, ids);
                if (!espOk)
                {
                    mensajeError = espErr;
                    return;
                }
            }

            mensajeExito = "Cambios guardados correctamente.";
            dropdownEspAbiertoId = null;
            await CargarUsuariosAsync();
        }
        finally
        {
            guardandoId = null;
        }
    }

    private async Task CargarUsuariosAsync()
    {
        cargando = true;
        mensajeError = null;
        try
        {
            var result = await UsuariosService.GetUsuariosAsync(1, 500);
            usuarios = result.Items;
            totalUsuarios = result.TotalCount;
            pendientesSinRol = usuarios.Count(u => (u.Roles ?? []).Count == 0);

            rolesSeleccionados.Clear();
            especializacionesSeleccionadas.Clear();
            foreach (var u in usuarios)
            {
                var roles = u.Roles ?? [];
                var rolActual = RolNombreToId(roles.FirstOrDefault());
                rolesSeleccionados[u.IdUsuario] = rolActual;
                especializacionesSeleccionadas[u.IdUsuario] = (u.Especializaciones ?? [])
                    .Select(e => e.IdEspecializacionMecanico)
                    .ToHashSet();
            }
        }
        catch
        {
            mensajeError = "No se pudo cargar la lista de usuarios.";
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task RegistrarUsuarioAsync()
    {
        mensajeRegistroError = null;
        mensajeRegistroExito = null;

        if (string.IsNullOrWhiteSpace(nuevoUsuario.Nombres)
            || string.IsNullOrWhiteSpace(nuevoUsuario.Apellidos)
            || string.IsNullOrWhiteSpace(nuevoUsuario.Correo)
            || string.IsNullOrWhiteSpace(nuevoUsuario.Password))
        {
            mensajeRegistroError = "Completa todos los campos.";
            return;
        }

        if (nuevoUsuario.Password.Length < 6)
        {
            mensajeRegistroError = "La contraseña debe tener al menos 6 caracteres.";
            return;
        }

        registrandoUsuario = true;
        try
        {
            var (success, error) = await UsuariosService.RegisterUsuarioAsync(nuevoUsuario);
            if (!success)
            {
                mensajeRegistroError = error;
                return;
            }

            mensajeRegistroExito = "Usuario registrado. Asigna su rol en la tabla.";
            nuevoUsuario.Nombres = string.Empty;
            nuevoUsuario.Apellidos = string.Empty;
            nuevoUsuario.Correo = string.Empty;
            nuevoUsuario.Password = string.Empty;
            await CargarUsuariosAsync();
        }
        finally
        {
            registrandoUsuario = false;
        }
    }

    private void OnRolSeleccionadoChanged(int idUsuario, ChangeEventArgs e)
    {
        if (e.Value is null)
        {
            rolesSeleccionados[idUsuario] = 0;
            return;
        }

        if (int.TryParse(Convert.ToString(e.Value, CultureInfo.InvariantCulture), NumberStyles.Integer, CultureInfo.InvariantCulture, out var idRol))
        {
            rolesSeleccionados[idUsuario] = idRol;
            if (idRol != 2)
                CerrarEspDropdown();
        }
    }
}
