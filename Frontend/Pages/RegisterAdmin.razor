@page "/registro/admin"
@layout AuthLayout

<PageTitle>Registro administrador — Mecánicas Jholversito</PageTitle>

<div class="flex min-h-screen">
    <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden bg-gradient-to-br from-red-950 via-red-900 to-slate-900">
        <div class="absolute inset-0 opacity-20"
             style="background-image: radial-gradient(circle at 20% 80%, #6366f1 0%, transparent 50%), radial-gradient(circle at 80% 20%, #8b5cf6 0%, transparent 40%);"></div>
        <div class="relative z-10 flex flex-col justify-center px-16 text-white">
            <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-red-500 text-lg font-bold shadow-2xl shadow-red-500/40 mb-8">
                AD
            </div>
            <h1 class="text-4xl font-bold tracking-tight mb-4">Panel<br/>Administrador</h1>
            <p class="text-red-200 text-lg leading-relaxed max-w-md">
                Crea la cuenta principal del taller. Control total sobre usuarios, clientes y configuración del sistema.
            </p>
            <ul class="mt-10 space-y-3 text-red-300/80 text-sm">
                <li class="flex items-center gap-2"><span class="inline-block h-1.5 w-1.5 rounded-full bg-red-400"></span> Gestión de personal</li>
                <li class="flex items-center gap-2"><span class="inline-block h-1.5 w-1.5 rounded-full bg-red-400"></span> Acceso a reportes</li>
                <li class="flex items-center gap-2"><span class="inline-block h-1.5 w-1.5 rounded-full bg-red-400"></span> Configuración del taller</li>
            </ul>
        </div>
    </div>

    <div class="flex flex-1 items-center justify-center p-6 sm:p-12 bg-slate-50">
        <div class="w-full max-w-md">
            <div class="lg:hidden flex items-center gap-3 mb-8">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-red-600 text-xs font-bold text-white">AD</div>
                <div>
                    <p class="font-bold text-slate-800 text-lg">Registro administrador</p>
                    <p class="text-slate-500 text-sm">Cuenta con permisos completos</p>
                </div>
            </div>

            <div class="bg-white rounded-2xl shadow-xl shadow-slate-200/60 border border-slate-100 p-8">
                <h2 class="text-2xl font-bold text-slate-800 mb-1">Crear admin</h2>

                @if (adminDisponible)
                {
                    <p class="text-slate-500 text-sm mb-6">Primer administrador del sistema. Completa tus datos.</p>
                }
                else if (esAdmin)
                {
                    <p class="text-slate-500 text-sm mb-6">Registra un nuevo administrador desde tu sesión activa.</p>
                }
                else if (AuthService.IsAuthenticated)
                {
                    <div class="rounded-xl bg-red-50 border border-red-100 p-4 mb-6 text-sm text-red-800">
                        Solo un administrador puede registrar otra cuenta admin.
                    </div>
                }
                else
                {
                    <div class="rounded-xl bg-red-50 border border-red-100 p-4 mb-6 text-sm text-red-800">
                        Ya existe un administrador. <a href="/login?returnUrl=/registro/admin" class="font-semibold underline">Inicia sesión como admin</a> para registrar otro.
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(mensajeExito))
                {
                    <div class="rounded-xl bg-red-50 border border-red-100 p-4 mb-6 text-sm text-red-700">
                        @mensajeExito
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(mensajeError))
                {
                    <div class="rounded-xl bg-red-50 border border-red-100 p-4 mb-6 text-sm text-red-700">
                        @mensajeError
                    </div>
                }

                @if (puedeRegistrar)
                {
                    <EditForm Model="modelo" OnValidSubmit="RegistrarAsync" class="space-y-4">
                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Nombres</label>
                                <input type="text" @bind="modelo.Nombres" required
                                       class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50 focus:outline-none focus:ring-2 focus:ring-red-500" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-1">Apellidos</label>
                                <input type="text" @bind="modelo.Apellidos" required
                                       class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50 focus:outline-none focus:ring-2 focus:ring-red-500" />
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Correo</label>
                            <input type="email" @bind="modelo.Correo" required placeholder="admin@taller.com"
                                   class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50 focus:outline-none focus:ring-2 focus:ring-red-500" />
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Contraseña</label>
                            <input type="password" @bind="modelo.Password" required minlength="6"
                                   class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50 focus:outline-none focus:ring-2 focus:ring-red-500" />
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Confirmar contraseña</label>
                            <input type="password" @bind="modelo.ConfirmPassword" required
                                   class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50 focus:outline-none focus:ring-2 focus:ring-red-500" />
                        </div>

                        <button type="submit" disabled="@cargando"
                                class="w-full flex items-center justify-center gap-2 px-4 py-3.5 rounded-xl bg-red-600 hover:bg-red-700 disabled:opacity-60 text-white font-semibold shadow-lg shadow-red-500/30 transition-all">
                            @if (cargando)
                            {
                                <span class="inline-block h-4 w-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                                <span>Registrando...</span>
                            }
                            else
                            {
                                <span>Crear cuenta admin</span>
                            }
                        </button>
                    </EditForm>
                }
            </div>

            <div class="mt-6 text-center text-sm text-slate-500">
                <a href="/login" class="text-red-600 hover:text-red-700 font-medium">← Volver al login</a>
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] private IUsuariosService UsuariosService { get; set; } = null!;
    [Inject] private AuthService AuthService { get; set; } = null!;
    [Inject] private NavigationManager Navigation { get; set; } = null!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = null!;

    private readonly RegisterUserDto modelo = new();
    private bool adminDisponible;
    private bool esAdmin;
    private bool puedeRegistrar;
    private bool cargando;
    private string? mensajeError;
    private string? mensajeExito;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        adminDisponible = await UsuariosService.IsAdminRegistrationAvailableAsync();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        esAdmin = authState.User.IsInRole("Admin");
        puedeRegistrar = adminDisponible || esAdmin;
    }

    private async Task RegistrarAsync()
    {
        mensajeError = null;
        mensajeExito = null;

        if (modelo.Password != modelo.ConfirmPassword)
        {
            mensajeError = "Las contraseñas no coinciden.";
            return;
        }

        if (modelo.Password.Length < 6)
        {
            mensajeError = "La contraseña debe tener al menos 6 caracteres.";
            return;
        }

        cargando = true;
        try
        {
            var (success, error) = await UsuariosService.RegisterAdminAsync(modelo);
            if (!success)
            {
                mensajeError = error;
                return;
            }

            var (loginOk, loginError) = await AuthService.LoginAsync(modelo.Correo.Trim(), modelo.Password);
            if (loginOk)
            {
                if (AuthStateProvider is JwtAuthStateProvider jwtProvider)
                    await jwtProvider.GetAuthenticationStateAsync();
                Navigation.NavigateTo("/", replace: true);
                return;
            }

            mensajeExito = "Cuenta creada. " + (loginError ?? "Inicia sesión para continuar.");
            Navigation.NavigateTo("/login");
        }
        finally
        {
            cargando = false;
        }
    }
}
