@page "/mecanico/orden/{IdOrdenServicio:int}"
@layout MainLayout
@attribute [Authorize(Roles = "Mecánico")]
@using Frontend.Models
@inject IDiagnosticoClientService Diagnostico
@inject IOrdenesService OrdenesService
@inject IUsuariosService UsuariosService

<PageTitle>Diagnóstico — Orden #@IdOrdenServicio</PageTitle>

<div class="max-w-5xl mx-auto space-y-8 pb-10">
    <header class="border-b border-slate-200 pb-6">
        <p class="text-xs font-semibold uppercase tracking-widest text-red-600">Mecánico</p>
        <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
                <h1 class="text-3xl font-bold tracking-tight text-slate-900 mt-1">Orden #@IdOrdenServicio</h1>
                <p class="text-sm text-slate-600 mt-2">Revisa el vehículo, registra hallazgos y propón reparaciones.</p>
            </div>
            @if (!string.IsNullOrWhiteSpace(_estadoOrden))
            {
                <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold bg-slate-100 text-slate-800">
                    @_estadoOrden
                </span>
            }
        </div>
    </header>

    @if (_estadoOrden == "Recibido")
    {
        <div class="rounded-2xl border border-blue-200 bg-blue-50 px-5 py-4 flex flex-wrap items-center justify-between gap-4">
            <p class="text-sm text-blue-900">
                El vehículo fue recibido. Inicia la revisión/diagnóstico cuando comiences a trabajar en la orden.
            </p>
            <button class="px-4 py-2 rounded-lg text-sm font-medium bg-blue-600 text-white hover:bg-blue-700 disabled:opacity-60 shrink-0"
                    disabled="@_iniciandoDiag"
                    @onclick="IniciarDiagnosticoAsync">
                Iniciar revisión / diagnóstico
            </button>
        </div>
    }

    @if (_loading)
    {
        <div class="h-24 animate-pulse rounded-2xl bg-slate-200/80"></div>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="rounded-2xl border border-red-200 bg-red-50 px-5 py-4 text-sm text-red-800">@_error</div>
    }

    <section class="rounded-2xl border border-slate-200 bg-white p-6 space-y-4">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h2 class="text-lg font-bold text-slate-900">Diagnóstico</h2>
                <p class="text-sm text-slate-600">Sintomas, hallazgos y recomendaciones.</p>
            </div>
            <button class="px-4 py-2 rounded-lg text-sm bg-red-600 text-white hover:bg-red-700 disabled:opacity-60"
                    disabled="@(_savingDiag || _diagnosticoBloqueado)"
                    @onclick="GuardarDiagnosticoAsync">
                Guardar
            </button>
        </div>

        @if (_diagnosticoBloqueado)
        {
            <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
                El diagnóstico ya no se puede editar porque la reparación ya inició.
            </div>
        }

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="md:col-span-1">
                <label class="text-xs font-semibold text-slate-600">Síntomas reportados</label>
                <textarea class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-800"
                          rows="4"
                          disabled="@_diagnosticoBloqueado"
                          @bind="_diagForm.SintomasReportados"></textarea>
            </div>
            <div class="md:col-span-1">
                <label class="text-xs font-semibold text-slate-600">Hallazgos</label>
                <textarea class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-800"
                          rows="4"
                          disabled="@_diagnosticoBloqueado"
                          @bind="_diagForm.Hallazgos"></textarea>
            </div>
            <div class="md:col-span-1">
                <label class="text-xs font-semibold text-slate-600">Recomendaciones</label>
                <textarea class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-800"
                          rows="4"
                          disabled="@_diagnosticoBloqueado"
                          @bind="_diagForm.Recomendaciones"></textarea>
            </div>
        </div>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6 space-y-4">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h2 class="text-lg font-bold text-slate-900">Reparaciones propuestas</h2>
                <p class="text-sm text-slate-600">Cada ítem se envía al jefe para aprobación y luego al cliente.</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-6 gap-3">
            <div class="md:col-span-2">
                <label class="text-xs font-semibold text-slate-600">Descripción</label>
                <input class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-800"
                       @bind="_newItem.Descripcion" />
            </div>
            <div class="md:col-span-2">
                <label class="text-xs font-semibold text-slate-600">Especialización requerida</label>
                <select class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-800"
                        @bind="_newItem.IdEspecializacionMecanico">
                    <option value="0">Seleccionar...</option>
                    @foreach (var esp in _especializaciones)
                    {
                        <option value="@esp.IdEspecializacionMecanico">@esp.Nombre</option>
                    }
                </select>
            </div>
            <div class="md:col-span-1">
                <label class="text-xs font-semibold text-slate-600">Costo estimado</label>
                <input type="number"
                       class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-800"
                       @bind="_newItem.CostoEstimado" />
            </div>
            <div class="md:col-span-1 flex items-end">
                <button class="w-full px-4 py-2 rounded-lg text-sm bg-slate-900 text-white hover:bg-slate-800 disabled:opacity-60"
                        disabled="@(_savingItem || string.IsNullOrWhiteSpace(_newItem.Descripcion) || _newItem.IdEspecializacionMecanico <= 0)"
                        @onclick="AgregarItemAsync">
                    Agregar
                </button>
            </div>
        </div>

        @if (_items.Count == 0)
        {
            <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-600">
                Todavía no hay ítems de reparación.
            </div>
        }
        else
        {
            <div class="overflow-hidden rounded-xl border border-slate-200">
                <table class="min-w-full text-sm bg-white">
                    <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                        <tr>
                            <th class="px-4 py-3">#</th>
                            <th class="px-4 py-3">Descripción</th>
                            <th class="px-4 py-3">Especialización</th>
                            <th class="px-4 py-3">Costo</th>
                            <th class="px-4 py-3">Estado</th>
                            <th class="px-4 py-3 text-right">Acción</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var it in _items)
                        {
                            <tr>
                                <td class="px-4 py-3 text-slate-700">@it.Orden</td>
                                <td class="px-4 py-3 text-slate-900">@it.Descripcion</td>
                                <td class="px-4 py-3 text-slate-700">@it.EspecializacionNombre</td>
                                <td class="px-4 py-3 text-slate-700">@it.CostoEstimado.ToString("C0")</td>
                                <td class="px-4 py-3 text-slate-700">@it.Estado</td>
                                <td class="px-4 py-3 text-right">
                                    @if (it.Estado == "Aprobado por cliente")
                                    {
                                        <button class="px-3 py-1.5 rounded-lg text-xs bg-blue-600 text-white hover:bg-blue-700 disabled:opacity-60"
                                                disabled="@_savingItem"
                                                @onclick="() => IniciarAsync(it.IdReparacionItem)">
                                            Iniciar
                                        </button>
                                    }
                                    else if (it.Estado == "En proceso")
                                    {
                                        <button class="px-3 py-1.5 rounded-lg text-xs bg-emerald-600 text-white hover:bg-emerald-700 disabled:opacity-60"
                                                disabled="@_savingItem"
                                                @onclick="() => TerminarAsync(it.IdReparacionItem)">
                                            Terminar
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-xs text-slate-500">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

@code {
    [Parameter] public int IdOrdenServicio { get; set; }

    private bool _loading = true;
    private string? _error;
    private bool _savingDiag;
    private bool _savingItem;
    private bool _iniciandoDiag;
    private bool _diagnosticoBloqueado;
    private string? _estadoOrden;

    private UpsertDiagnosticoDto _diagForm = new();
    private CreateReparacionItemDto _newItem = new();
    private List<ReparacionItemDto> _items = [];
    private List<EspecializacionMecanicoDto> _especializaciones = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _especializaciones = await UsuariosService.GetEspecializacionesAsync();
            var orden = await OrdenesService.GetOrdenAsync(IdOrdenServicio);
            _estadoOrden = orden?.Estado;
            var diag = await Diagnostico.GetDiagnosticoAsync(IdOrdenServicio);
            _diagForm = new UpsertDiagnosticoDto
            {
                SintomasReportados = diag?.SintomasReportados,
                Hallazgos = diag?.Hallazgos,
                Recomendaciones = diag?.Recomendaciones
            };
            _items = await Diagnostico.GetReparacionesAsync(IdOrdenServicio);
            _diagnosticoBloqueado = _items.Any(i => i.Estado is "En proceso" or "Terminado");
        }
        catch (Exception ex)
        {
            _error = $"No se pudo cargar la orden. {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task IniciarDiagnosticoAsync()
    {
        if (_iniciandoDiag || _estadoOrden != "Recibido")
            return;

        _iniciandoDiag = true;
        _error = null;
        try
        {
            await Diagnostico.IniciarDiagnosticoAsync(IdOrdenServicio);
            _estadoOrden = "Diagnóstico en proceso";
        }
        catch (Exception ex)
        {
            _error = $"No se pudo iniciar el diagnóstico. {ex.Message}";
        }
        finally
        {
            _iniciandoDiag = false;
        }
    }

    private async Task GuardarDiagnosticoAsync()
    {
        if (_savingDiag || _diagnosticoBloqueado)
            return;

        _savingDiag = true;
        _error = null;
        try
        {
            await Diagnostico.UpsertDiagnosticoAsync(IdOrdenServicio, _diagForm);
        }
        catch (Exception ex)
        {
            _error = $"No se pudo guardar el diagnóstico. {ex.Message}";
        }
        finally
        {
            _savingDiag = false;
        }
    }

    private async Task AgregarItemAsync()
    {
        if (_savingItem)
            return;

        _savingItem = true;
        _error = null;
        try
        {
            await Diagnostico.CrearReparacionAsync(IdOrdenServicio, _newItem);
            _newItem = new CreateReparacionItemDto();
            _items = await Diagnostico.GetReparacionesAsync(IdOrdenServicio);
            var orden = await OrdenesService.GetOrdenAsync(IdOrdenServicio);
            _estadoOrden = orden?.Estado;
        }
        catch (Exception ex)
        {
            _error = $"No se pudo agregar el ítem. {ex.Message}";
        }
        finally
        {
            _savingItem = false;
        }
    }

    private async Task IniciarAsync(int idReparacionItem)
    {
        if (_savingItem)
            return;

        _savingItem = true;
        _error = null;
        try
        {
            await Diagnostico.IniciarReparacionAsync(IdOrdenServicio, idReparacionItem);
            _items = await Diagnostico.GetReparacionesAsync(IdOrdenServicio);
        }
        catch (Exception ex)
        {
            _error = $"No se pudo iniciar la reparación. {ex.Message}";
        }
        finally
        {
            _savingItem = false;
        }
    }

    private async Task TerminarAsync(int idReparacionItem)
    {
        if (_savingItem)
            return;

        _savingItem = true;
        _error = null;
        try
        {
            await Diagnostico.TerminarReparacionAsync(IdOrdenServicio, idReparacionItem);
            _items = await Diagnostico.GetReparacionesAsync(IdOrdenServicio);
        }
        catch (Exception ex)
        {
            _error = $"No se pudo terminar la reparación. {ex.Message}";
        }
        finally
        {
            _savingItem = false;
        }
    }
}

