@page "/clientes"
@layout MainLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IClientesService ClientesService
@inject IJSRuntime JsRuntime

<div class="space-y-6">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <h1 class="text-2xl font-semibold text-slate-800">Clientes — MecanicasJholversito</h1>
        <button type="button"
                class="inline-flex items-center px-4 py-2 bg-red-500 text-white text-sm font-medium rounded-md hover:bg-red-600"
                @onclick="OpenCreateForm">
            Nuevo cliente
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(mensajeExito))
    {
        <div class="rounded-md bg-green-50 p-4 mb-4 text-sm text-green-800">
            @mensajeExito
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(mensajeError))
    {
        <div class="rounded-md bg-red-50 p-4 mb-4 text-sm text-red-800">
            @mensajeError
        </div>
    }

    <div class="flex flex-col gap-3 md:flex-row md:items-center">
        <input type="text"
               placeholder="Buscar por nombre o correo..."
               class="w-full md:w-1/3 px-3 py-2 border border-slate-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
               @bind="filtro"
               @bind:event="oninput"
               @onkeydown="OnSearchKeyDown" />
        <button type="button"
                class="inline-flex items-center px-4 py-2 bg-red-500 text-white text-sm font-medium rounded-md hover:bg-red-600"
                @onclick="OnSearchChanged">
            Buscar
        </button>
    </div>

    @if (cargando)
    {
        <p class="text-sm text-slate-500">Cargando clientes...</p>
    }
    else
    {
        <div class="overflow-x-auto bg-white shadow rounded-lg">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Nombre</th>
                        <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Correo</th>
                        <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Teléfono</th>
                        <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Estado</th>
                        <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200">
                    @if (clientes.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="px-4 py-6 text-center text-sm text-slate-500">
                                No se encontraron clientes.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var cliente in clientes)
                        {
                            <tr>
                                <td class="px-4 py-2 whitespace-nowrap text-sm text-slate-700">
                                    @($"{cliente.Nombres} {cliente.Apellidos}".Trim())
                                </td>
                                <td class="px-4 py-2 whitespace-nowrap text-sm text-slate-700">@cliente.CorreoPrincipal</td>
                                <td class="px-4 py-2 whitespace-nowrap text-sm text-slate-700">@cliente.TelefonoPrincipal</td>
                                <td class="px-4 py-2 whitespace-nowrap text-sm text-slate-700">
                                    @if (cliente.Estado)
                                    {
                                        <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600">Inactivo</span>
                                    }
                                </td>
                                <td class="px-4 py-2 whitespace-nowrap text-sm text-slate-700 space-x-2">
                                    <button type="button"
                                            class="inline-flex items-center px-3 py-1.5 bg-slate-100 text-slate-700 text-xs font-medium rounded-md hover:bg-slate-200"
                                            @onclick="() => OpenEditForm(cliente)">
                                        Editar
                                    </button>
                                    <button type="button"
                                            class="inline-flex items-center px-3 py-1.5 bg-red-600 text-white text-xs font-medium rounded-md hover:bg-red-700"
                                            @onclick="() => ConfirmarEliminarAsync(cliente.IdCliente)">
                                        Eliminar
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="flex items-center justify-between">
            <p class="text-sm text-slate-600">
                Página @PageNumber de @TotalPaginas (@TotalCount registros)
            </p>
            <div class="flex gap-2">
                <button type="button"
                        class="inline-flex items-center px-3 py-1.5 bg-slate-100 text-slate-700 text-xs font-medium rounded-md hover:bg-slate-200 disabled:opacity-50 disabled:cursor-not-allowed"
                        disabled="@(PageNumber <= 1)"
                        @onclick="GoToPreviousPage">
                    Anterior
                </button>
                <button type="button"
                        class="inline-flex items-center px-3 py-1.5 bg-slate-100 text-slate-700 text-xs font-medium rounded-md hover:bg-slate-200 disabled:opacity-50 disabled:cursor-not-allowed"
                        disabled="@(PageNumber >= TotalPaginas)"
                        @onclick="GoToNextPage">
                    Siguiente
                </button>
            </div>
        </div>
    }
</div>

@if (formularioVisible)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4">
        <div class="w-full max-w-lg rounded-lg bg-white shadow-xl">
            <div class="border-b border-slate-200 px-6 py-4">
                <h2 class="text-lg font-semibold text-slate-800">
                    @(modoEdicion ? "Editar cliente" : "Nuevo cliente")
                </h2>
            </div>

            <div class="space-y-4 px-6 py-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Nombres *</label>
                    <input type="text"
                           class="w-full px-3 py-2 border border-slate-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
                           @bind="formulario.Nombres" />
                    @if (erroresValidacion.TryGetValue(nameof(formulario.Nombres), out var errNombres))
                    {
                        <p class="mt-1 text-xs text-red-600">@errNombres</p>
                    }
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Apellidos *</label>
                    <input type="text"
                           class="w-full px-3 py-2 border border-slate-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
                           @bind="formulario.Apellidos" />
                    @if (erroresValidacion.TryGetValue(nameof(formulario.Apellidos), out var errApellidos))
                    {
                        <p class="mt-1 text-xs text-red-600">@errApellidos</p>
                    }
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Correo *</label>
                    <input type="email"
                           class="w-full px-3 py-2 border border-slate-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
                           @bind="formulario.Correo" />
                    @if (erroresValidacion.TryGetValue(nameof(formulario.Correo), out var errCorreo))
                    {
                        <p class="mt-1 text-xs text-red-600">@errCorreo</p>
                    }
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Teléfono *</label>
                    <input type="text"
                           class="w-full px-3 py-2 border border-slate-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
                           @bind="formulario.Telefono" />
                    @if (erroresValidacion.TryGetValue(nameof(formulario.Telefono), out var errTelefono))
                    {
                        <p class="mt-1 text-xs text-red-600">@errTelefono</p>
                    }
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Número de documento *</label>
                    <input type="text"
                           class="w-full px-3 py-2 border border-slate-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
                           @bind="formulario.NumeroDocumento" />
                    @if (erroresValidacion.TryGetValue(nameof(formulario.NumeroDocumento), out var errDocumento))
                    {
                        <p class="mt-1 text-xs text-red-600">@errDocumento</p>
                    }
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Tipo de documento *</label>
                    <select class="w-full px-3 py-2 border border-slate-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500"
                            @bind="formulario.IdTipoDocumento">
                        @foreach (var tipo in tiposDocumento)
                        {
                            <option value="@tipo.Id">@tipo.Nombre</option>
                        }
                    </select>
                    @if (erroresValidacion.TryGetValue(nameof(formulario.IdTipoDocumento), out var errTipo))
                    {
                        <p class="mt-1 text-xs text-red-600">@errTipo</p>
                    }
                </div>
            </div>

            <div class="flex justify-end gap-2 border-t border-slate-200 px-6 py-4">
                <button type="button"
                        class="inline-flex items-center px-3 py-1.5 bg-slate-100 text-slate-700 text-xs font-medium rounded-md hover:bg-slate-200"
                        @onclick="CerrarFormulario">
                    Cancelar
                </button>
                <button type="button"
                        class="inline-flex items-center px-4 py-2 bg-red-500 text-white text-sm font-medium rounded-md hover:bg-red-600"
                        @onclick="SaveClienteAsync">
                    Guardar
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<ClienteDto> clientes = [];
    private string? filtro;
    private bool formularioVisible;
    private bool modoEdicion;
    private int? idClienteEdicion;
    private CreateClienteDto formulario = new();
    private readonly Dictionary<string, string> erroresValidacion = new();

    private int PageNumber = 1;
    private int PageSize = 10;
    private int TotalCount;

    private bool cargando;
    private string? mensajeError;
    private string? mensajeExito;

    private int TotalPaginas => TotalCount == 0 ? 1 : (int)Math.Ceiling(TotalCount / (double)PageSize);

    private readonly List<(int Id, string Nombre)> tiposDocumento =
    [
        (1, "Cédula de ciudadanía"),
        (2, "Cédula de extranjería"),
        (3, "Pasaporte"),
        (4, "NIT")
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadClientesAsync();
    }

    private async Task LoadClientesAsync()
    {
        cargando = true;
        mensajeError = null;
        StateHasChanged();

        try
        {
            var result = await ClientesService.GetClientesAsync(PageNumber, PageSize, filtro);
            clientes = result.Items;
            TotalCount = result.TotalCount;

            if (PageNumber > TotalPaginas)
            {
                PageNumber = TotalPaginas;
                result = await ClientesService.GetClientesAsync(PageNumber, PageSize, filtro);
                clientes = result.Items;
                TotalCount = result.TotalCount;
            }
        }
        catch
        {
            mensajeError = "Ocurrió un error al procesar la solicitud. Intenta nuevamente.";
            clientes = [];
            TotalCount = 0;
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task OnSearchChanged()
    {
        PageNumber = 1;
        await LoadClientesAsync();
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await OnSearchChanged();
    }

    private void OpenCreateForm()
    {
        mensajeError = null;
        mensajeExito = null;
        modoEdicion = false;
        idClienteEdicion = null;
        formulario = new CreateClienteDto { IdTipoDocumento = tiposDocumento[0].Id };
        erroresValidacion.Clear();
        formularioVisible = true;
    }

    private void OpenEditForm(ClienteDto cliente)
    {
        mensajeError = null;
        mensajeExito = null;
        modoEdicion = true;
        idClienteEdicion = cliente.IdCliente;
        formulario = new CreateClienteDto
        {
            Nombres = cliente.Nombres,
            Apellidos = cliente.Apellidos,
            Correo = cliente.CorreoPrincipal,
            Telefono = cliente.TelefonoPrincipal,
            NumeroDocumento = cliente.NumeroDocumento,
            IdTipoDocumento = cliente.IdTipoDocumento > 0 ? cliente.IdTipoDocumento : tiposDocumento[0].Id
        };
        erroresValidacion.Clear();
        formularioVisible = true;
    }

    private void CerrarFormulario()
    {
        formularioVisible = false;
        erroresValidacion.Clear();
    }

    private bool ValidarFormulario()
    {
        erroresValidacion.Clear();

        if (string.IsNullOrWhiteSpace(formulario.Nombres))
            erroresValidacion[nameof(formulario.Nombres)] = "Los nombres son obligatorios.";

        if (string.IsNullOrWhiteSpace(formulario.Apellidos))
            erroresValidacion[nameof(formulario.Apellidos)] = "Los apellidos son obligatorios.";

        if (string.IsNullOrWhiteSpace(formulario.Correo))
            erroresValidacion[nameof(formulario.Correo)] = "El correo es obligatorio.";

        if (string.IsNullOrWhiteSpace(formulario.Telefono))
            erroresValidacion[nameof(formulario.Telefono)] = "El teléfono es obligatorio.";

        if (string.IsNullOrWhiteSpace(formulario.NumeroDocumento))
            erroresValidacion[nameof(formulario.NumeroDocumento)] = "El número de documento es obligatorio.";

        if (formulario.IdTipoDocumento <= 0)
            erroresValidacion[nameof(formulario.IdTipoDocumento)] = "Seleccione un tipo de documento.";

        return erroresValidacion.Count == 0;
    }

    private async Task SaveClienteAsync()
    {
        mensajeError = null;
        mensajeExito = null;

        if (!ValidarFormulario())
            return;

        try
        {
            if (modoEdicion && idClienteEdicion.HasValue)
                await ClientesService.UpdateClienteAsync(idClienteEdicion.Value, formulario);
            else
                await ClientesService.CreateClienteAsync(formulario);

            formularioVisible = false;
            mensajeExito = modoEdicion ? "Cliente actualizado correctamente." : "Cliente creado correctamente.";
            if (!modoEdicion)
            {
                filtro = null;
                PageNumber = 1;
            }
            await LoadClientesAsync();
        }
        catch (HttpRequestException ex) when (ex.Message.Contains("órdenes", StringComparison.OrdinalIgnoreCase)
                                              || ex.Message.Contains("400"))
        {
            mensajeError = ExtraerMensajeApi(ex.Message);
            formularioVisible = false;
        }
        catch
        {
            mensajeError = "Ocurrió un error al procesar la solicitud. Intenta nuevamente.";
        }
    }

    private async Task ConfirmarEliminarAsync(int id)
    {
        mensajeError = null;
        mensajeExito = null;

        var confirmado = await JsRuntime.InvokeAsync<bool>("confirm", "¿Seguro que deseas eliminar este cliente?");
        if (!confirmado)
            return;

        await DeleteClienteAsync(id);
    }

    private async Task DeleteClienteAsync(int id)
    {
        try
        {
            await ClientesService.DeleteClienteAsync(id);
            mensajeExito = "Cliente eliminado correctamente.";
            await LoadClientesAsync();
        }
        catch (HttpRequestException ex)
        {
            mensajeError = ExtraerMensajeApi(ex.Message);
        }
        catch
        {
            mensajeError = "Ocurrió un error al procesar la solicitud. Intenta nuevamente.";
        }
    }

    private async Task GoToNextPage()
    {
        if (PageNumber >= TotalPaginas)
            return;

        PageNumber++;
        await LoadClientesAsync();
    }

    private async Task GoToPreviousPage()
    {
        if (PageNumber <= 1)
            return;

        PageNumber--;
        await LoadClientesAsync();
    }

    private static string ExtraerMensajeApi(string raw)
    {
        const string marker = "\"message\":\"";
        var start = raw.IndexOf(marker, StringComparison.Ordinal);
        if (start < 0)
            return "Ocurrió un error al procesar la solicitud. Intenta nuevamente.";

        start += marker.Length;
        var end = raw.IndexOf('"', start);
        return end > start ? raw[start..end] : raw;
    }
}
