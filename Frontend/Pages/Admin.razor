@page "/admin"

@layout MainLayout

@attribute [Authorize(Roles = "Admin")]

@inject IDashboardService DashboardService

@inject IEmpleadosService EmpleadosService



<PageTitle>Panel de administración — Mecánicas Jholversito</PageTitle>



<div class="max-w-6xl mx-auto space-y-10 pb-8">

    <header class="flex flex-col gap-4 border-b border-slate-200 pb-8 sm:flex-row sm:items-end sm:justify-between">

        <div class="space-y-2">

            <p class="text-xs font-semibold uppercase tracking-widest text-red-600">Área restringida</p>

            <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Panel de administración</h1>

            <p class="max-w-xl text-sm leading-relaxed text-slate-600">

                Vista general del taller. Personal, órdenes y acceso a todos los módulos.

            </p>

        </div>

        <button type="button"

                disabled="@cargando"

                class="inline-flex shrink-0 items-center justify-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 shadow-sm transition hover:border-red-200 hover:bg-red-50 hover:text-red-800 disabled:cursor-not-allowed disabled:opacity-50"

                @onclick="RecargarAsync">

            @if (cargando)

            {

                <span class="h-4 w-4 animate-spin rounded-full border-2 border-slate-300 border-t-red-600"></span>

                <span>Actualizando</span>

            }

            else

            {

                <span>Actualizar datos</span>

            }

        </button>

    </header>



    @if (cargando && dashboard is null)

    {

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">

            @for (var i = 0; i < 4; i++)

            {

                <div class="h-28 animate-pulse rounded-2xl bg-slate-200/80"></div>

            }

        </div>

    }

    else if (!string.IsNullOrWhiteSpace(error))

    {

        <div class="flex flex-col gap-3 rounded-2xl border border-red-200 bg-red-50 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">

            <p class="text-sm font-medium text-red-900">@error</p>

            <button type="button"

                    class="rounded-lg bg-white px-3 py-1.5 text-sm font-medium text-red-700 shadow-sm ring-1 ring-red-200 hover:bg-red-50"

                    @onclick="RecargarAsync">

                Reintentar

            </button>

        </div>

    }

    else if (dashboard is not null)

    {

        <section aria-label="Resumen del taller" class="space-y-4">

            <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">Resumen</h2>

            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">

                <article class="relative overflow-hidden rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm ring-1 ring-slate-900/5">

                    <div class="absolute left-0 top-0 h-full w-1 bg-red-500" aria-hidden="true"></div>

                    <p class="pl-3 text-xs font-semibold uppercase tracking-wide text-slate-500">Usuarios</p>

                    <p class="pl-3 mt-2 text-3xl font-bold tabular-nums text-slate-900">@dashboard.TotalUsuarios</p>

                    <p class="pl-3 mt-2 text-sm text-slate-600">

                        <span class="font-medium text-red-700">@dashboard.UsuariosPendientesRol</span> pendientes de rol

                    </p>

                </article>

                <article class="relative overflow-hidden rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm ring-1 ring-slate-900/5">

                    <div class="absolute left-0 top-0 h-full w-1 bg-slate-300" aria-hidden="true"></div>

                    <p class="pl-3 text-xs font-semibold uppercase tracking-wide text-slate-500">Empleados</p>

                    <p class="pl-3 mt-2 text-3xl font-bold tabular-nums text-slate-900">@dashboard.TotalEmpleados</p>

                    <p class="pl-3 mt-2 text-sm text-slate-500">Mecánicos y recepcionistas</p>

                </article>

                <article class="relative overflow-hidden rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm ring-1 ring-slate-900/5">

                    <div class="absolute left-0 top-0 h-full w-1 bg-slate-300" aria-hidden="true"></div>

                    <p class="pl-3 text-xs font-semibold uppercase tracking-wide text-slate-500">Clientes</p>

                    <p class="pl-3 mt-2 text-3xl font-bold tabular-nums text-slate-900">@dashboard.TotalClientes</p>

                    <p class="pl-3 mt-2 text-sm text-slate-500">@dashboard.TotalVehiculos vehículos registrados</p>

                </article>

                <a href="/usuarios"

                   class="group flex flex-col justify-between rounded-2xl border border-red-200 bg-gradient-to-br from-red-600 to-red-800 p-5 text-white shadow-md shadow-red-900/20 transition hover:shadow-lg hover:shadow-red-900/30 focus:outline-none focus-visible:ring-2 focus-visible:ring-red-400 focus-visible:ring-offset-2">

                    <div>

                        <p class="text-xs font-semibold uppercase tracking-wide text-red-100">Prioridad</p>

                        <p class="mt-2 text-lg font-semibold leading-snug">Asignar roles pendientes</p>

                        <p class="mt-1 text-sm text-red-100">Los usuarios sin rol no pueden iniciar sesión.</p>

                    </div>

                    <span class="mt-4 inline-flex items-center text-sm font-semibold text-white group-hover:gap-1">

                        Ir a usuarios

                        <span class="ml-1 transition-transform group-hover:translate-x-0.5" aria-hidden="true">→</span>

                    </span>

                </a>

            </div>

        </section>



        @if (dashboard.OrdenesPorEstado.Count > 0)

        {

            <section class="space-y-4">

                <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">Órdenes por estado</h2>

                <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">

                    @foreach (var par in dashboard.OrdenesPorEstado)

                    {

                        <div class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-center">

                            <p class="text-2xl font-bold text-slate-900">@par.Value</p>

                            <p class="text-xs font-medium text-slate-500 mt-1">@par.Key</p>

                        </div>

                    }

                </div>

            </section>

        }



        <section class="space-y-4">

            <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">Personal del taller</h2>

            @if (empleados.Count == 0)

            {

                <p class="text-sm text-slate-500">No hay empleados registrados con rol asignado.</p>

            }

            else

            {

                <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">

                    <div class="overflow-x-auto">

                        <table class="min-w-full text-sm">

                            <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">

                                <tr>

                                    <th class="px-5 py-3">Nombre</th>

                                    <th class="px-5 py-3">Correo</th>

                                    <th class="px-5 py-3">Rol</th>

                                </tr>

                            </thead>

                            <tbody class="divide-y divide-slate-100">

                                @foreach (var emp in empleados)

                                {

                                    <tr>

                                        <td class="px-5 py-3 font-medium text-slate-900">@emp.NombreCompleto</td>

                                        <td class="px-5 py-3 text-slate-600">@emp.Correo</td>

                                        <td class="px-5 py-3">

                                            <span class="inline-flex rounded-full bg-red-50 px-2.5 py-0.5 text-xs font-semibold text-red-700">

                                                @(emp.Roles.FirstOrDefault() ?? "—")

                                            </span>

                                        </td>

                                    </tr>

                                }

                            </tbody>

                        </table>

                    </div>

                </div>

            }

        </section>



        <section aria-label="Módulos del sistema" class="space-y-4">

            <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">Módulos</h2>

            <div class="grid grid-cols-1 gap-5 md:grid-cols-3">

                <a href="/usuarios"

                   class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-slate-900/5 transition hover:-translate-y-0.5 hover:border-red-200 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-red-500 focus-visible:ring-offset-2">

                    <span class="text-xs font-bold uppercase tracking-wider text-red-600">Personal</span>

                    <h3 class="mt-3 text-xl font-semibold text-slate-900">Usuarios y roles</h3>

                    <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">

                        Alta de cuentas, pendientes y asignación Mecánico o Recepcionista.

                    </p>

                    <span class="mt-5 text-sm font-semibold text-red-600 group-hover:underline">Abrir módulo</span>

                </a>

                <a href="/vehiculos"

                   class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-slate-900/5 transition hover:-translate-y-0.5 hover:border-red-200 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-red-500 focus-visible:ring-offset-2">

                    <span class="text-xs font-bold uppercase tracking-wider text-red-600">Flota</span>

                    <h3 class="mt-3 text-xl font-semibold text-slate-900">Vehículos</h3>

                    <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">

                        Listado por VIN, marca, modelo y kilometraje.

                    </p>

                    <span class="mt-5 text-sm font-semibold text-red-600 group-hover:underline">Abrir módulo</span>

                </a>

                <a href="/clientes"

                   class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-slate-900/5 transition hover:-translate-y-0.5 hover:border-red-200 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-red-500 focus-visible:ring-offset-2">

                    <span class="text-xs font-bold uppercase tracking-wider text-red-600">Cartera</span>

                    <h3 class="mt-3 text-xl font-semibold text-slate-900">Clientes</h3>

                    <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">

                        Búsqueda, alta y edición de clientes del taller.

                    </p>

                    <span class="mt-5 text-sm font-semibold text-red-600 group-hover:underline">Abrir módulo</span>

                </a>

            </div>

        </section>

    }

</div>



@code {

    private bool cargando = true;

    private string? error;

    private AdminDashboardDto? dashboard;

    private List<UsuarioDto> empleados = [];



    protected override async Task OnInitializedAsync() => await RecargarAsync();



    private async Task RecargarAsync()

    {

        error = null;

        cargando = true;

        try

        {

            dashboard = await DashboardService.GetAdminAsync();

            if (dashboard is null)

            {

                error = "No se pudo cargar el resumen. Comprueba que la API esté en ejecución.";

                return;

            }



            var empleadosResult = await EmpleadosService.GetEmpleadosAsync(1, 100);

            empleados = empleadosResult.Items;

        }

        catch

        {

            error = "No se pudo cargar el resumen. Comprueba que la API esté en ejecución.";

        }

        finally

        {

            cargando = false;

        }

    }

}

