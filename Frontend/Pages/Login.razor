@page "/login"
@layout AuthLayout

<PageTitle>Iniciar sesión — Mecánicas Jholversito</PageTitle>

<div class="flex min-h-screen">
    <!-- Panel branding -->
    <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden bg-gradient-to-br from-red-950 via-red-900 to-red-800">
        <div class="absolute inset-0 opacity-10"
             style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.4&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
        <div class="relative z-10 flex flex-col justify-center px-16 text-white">
            <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-red-500 text-lg font-bold shadow-2xl shadow-red-500/40 mb-8">
                MJ
            </div>
            <h1 class="text-4xl font-bold tracking-tight mb-4">Mecánicas<br/>Jholversito</h1>
            <p class="text-slate-300 text-lg leading-relaxed max-w-md">
                Sistema de gestión para tu taller automotriz. Clientes, órdenes y facturación en un solo lugar.
            </p>
            <ul class="mt-10 space-y-3 text-slate-400 text-sm">
                <li class="flex items-center gap-2"><span class="inline-block h-1.5 w-1.5 rounded-full bg-red-400"></span> Acceso seguro con JWT</li>
                <li class="flex items-center gap-2"><span class="inline-block h-1.5 w-1.5 rounded-full bg-red-400"></span> Gestión de clientes</li>
                <li class="flex items-center gap-2"><span class="inline-block h-1.5 w-1.5 rounded-full bg-red-400"></span> Panel administrativo</li>
            </ul>
        </div>
    </div>

    <!-- Formulario login -->
    <div class="flex flex-1 items-center justify-center p-6 sm:p-12 bg-slate-50">
        <div class="w-full max-w-md">
            <div class="lg:hidden flex items-center gap-3 mb-8">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-red-500 text-sm font-bold text-white">MJ</div>
                <div>
                    <p class="font-bold text-slate-800 text-lg">Mecánicas Jholversito</p>
                    <p class="text-slate-500 text-sm">Inicia sesión para continuar</p>
                </div>
            </div>

            <div class="bg-white rounded-2xl shadow-xl shadow-slate-200/60 border border-slate-100 p-8">
                <h2 class="text-2xl font-bold text-slate-800 mb-1">Bienvenido</h2>
                <p class="text-slate-500 text-sm mb-8">Ingresa tus credenciales de acceso</p>

                @if (Pendiente == "1")
                {
                    <div class="rounded-xl bg-red-50 border border-red-100 p-4 mb-6 text-sm text-red-700">
                        Registro exitoso. El administrador debe asignarte un rol antes de que puedas ingresar.
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(mensajeError))
                {
                    <div class="rounded-xl bg-red-50 border border-red-100 p-4 mb-6 text-sm text-red-700">
                        <span>@mensajeError</span>
                    </div>
                }

                <EditForm Model="modelo" OnValidSubmit="IniciarSesionAsync" class="space-y-5">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">Correo electrónico</label>
                        <input type="email"
                               @bind="modelo.Correo"
                               placeholder="example@email.com"
                               class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition-shadow" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">Contraseña</label>
                        <input type="password"
                               @bind="modelo.Password"
                               placeholder="••••••••"
                               class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition-shadow" />
                    </div>

                    <button type="submit"
                            disabled="@cargando"
                            class="w-full flex items-center justify-center gap-2 px-4 py-3.5 rounded-xl bg-red-500 hover:bg-red-600 disabled:opacity-60 disabled:cursor-not-allowed text-white font-semibold shadow-lg shadow-red-500/30 transition-all">
                        @if (cargando)
                        {
                            <span class="inline-block h-4 w-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                            <span>Ingresando...</span>
                        }
                        else
                        {
                            <span>Iniciar sesión</span>
                        }
                    </button>
                </EditForm>

                <div class="mt-8 pt-6 border-t border-slate-100 text-center">
                    <p class="text-sm text-slate-500 mb-3">¿No tienes cuenta?</p>
                    <a href="/registro"
                       class="flex w-full items-center justify-center px-4 py-3.5 rounded-xl border-2 border-red-200 bg-red-50 text-red-700 font-semibold text-sm hover:bg-red-100 transition-colors">
                        Regístrate
                    </a>
                    <p class="text-xs text-slate-400 mt-3">El super admin te asignará tu rol después del registro.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "pendiente")]
    public string? Pendiente { get; set; }

    [Inject] private AuthService AuthService { get; set; } = null!;
    [Inject] private NavigationManager Navigation { get; set; } = null!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = null!;

    private readonly LoginRequest modelo = new();
    private bool cargando;
    private string? mensajeError;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        if (AuthService.IsAuthenticated)
            Navigation.NavigateTo(string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl);
    }

    private async Task IniciarSesionAsync()
    {
        mensajeError = null;

        if (string.IsNullOrWhiteSpace(modelo.Correo) || string.IsNullOrWhiteSpace(modelo.Password))
        {
            mensajeError = "Ingresa correo y contraseña.";
            return;
        }

        cargando = true;
        try
        {
            var (success, error) = await AuthService.LoginAsync(modelo.Correo.Trim(), modelo.Password);
            if (!success)
            {
                mensajeError = error;
                return;
            }

            if (AuthStateProvider is JwtAuthStateProvider jwtProvider)
                await jwtProvider.GetAuthenticationStateAsync();

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var destino = string.IsNullOrWhiteSpace(ReturnUrl)
                ? RoleNavigation.GetHomeRoute(authState.User)
                : ReturnUrl;
            Navigation.NavigateTo(destino, replace: true);
        }
        finally
        {
            cargando = false;
        }
    }
}
