<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly" NotFoundPage="typeof(Pages.NotFound)">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated != true)
                    {
                        <RedirectToLogin />
                    }
                    else
                    {
                        <div class="flex min-h-screen items-center justify-center bg-slate-100 p-6">
                            <div class="rounded-xl bg-white p-8 shadow-lg text-center max-w-md border border-red-100">
                                <p class="text-3xl font-bold text-red-600 mb-4">403</p>
                                <h1 class="text-xl font-semibold text-slate-800">Acceso denegado</h1>
                                <p class="text-slate-500 mt-2 text-sm">No tienes permisos para ver esta sección.</p>
                            </div>
                        </div>
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
    </Router>
</CascadingAuthenticationState>